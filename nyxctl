#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/log.sh
source "$SCRIPT_DIR/lib/log.sh"
source "$SCRIPT_DIR/lib/util.sh"
source "$SCRIPT_DIR/lib/chezmoi.sh"
source "$SCRIPT_DIR/lib/config.sh"
source "$SCRIPT_DIR/lib/detect.sh"
source "$SCRIPT_DIR/lib/help.sh"

main() {
	case "${1:-}" in
	-h | --help | "")
		show_help
		exit 0
		;;
	init)
		if is_help_flag "${2:-}"; then
			show_init_help
			exit 0
		fi
		cmd_init "$@"
		;;
	apply) cmd_apply "${@:2}" ;;
	diff) cmd_diff ;;
	status) cmd_status ;;
	doctor) cmd_doctor ;;
	*)
		log_error "Usage: nyxctl {init|apply|diff|doctor}"
		exit 1
		;;
	esac
}

main "$@"
